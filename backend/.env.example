# CareerIQ Backend – Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────
# Local PostgreSQL (recommended for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/careeriq

# OR keep SQLite for development (default if not set)
# DATABASE_URL=sqlite:///./career_iq.db

# ── JWT ───────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-use-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Email OTP (optional – prints to console if left empty) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@careeriq.ai

# ── Twilio SMS OTP (optional – prints to console if left empty) ─────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+1234567890

# ── Other (optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
